-- ── Cycling helper ────────────────────────────────────────────────────────────
-- Caches the list on first press, advances one item per press, rescans when
-- exhausted. Each cycler is its own closure with independent state.
local function makeCycler(label, getList, getPosFn)
    local list   = {}
    local cursor = 0

    return function()
        if cursor <= 0 or cursor > #list then
            list   = getList()
            cursor = 1
            if #list == 0 then
                Library:Notify(label .. " — nothing found!", 3)
                return
            end
        end

        -- Skip stale (removed) entries
        while cursor <= #list and not (list[cursor] and list[cursor].Parent) do
            cursor += 1
        end

        if cursor > #list then
            cursor = 0
            Library:Notify(label .. " — list exhausted, rescanning next press.", 3)
            return
        end

        local pos = getPosFn(list[cursor])
        if pos then
            safeTeleport(pos)
            Library:Notify(("%s  %d / %d"):format(label, cursor, #list), 2)
        end
        cursor += 1
    end
end

