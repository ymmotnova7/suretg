task.spawn(function()
    while true do
        task.wait(0.5)
        if not tog("AutoRaid") then continue end

        local currentPlaceId = game.PlaceId

        -- ── LOBBY PHASE ───────────────────────────────────────────────────────
        if currentPlaceId == LOBBY_PLACE_ID then
            setRaidStatus("In lobby — creating party...")
            task.wait(2)

            -- Create squad
            pcall(function()
                local RS = game:GetService("ReplicatedStorage")
                local createSquad = RS.Requests:FindFirstChild("CreateSquad")
                if createSquad then
                    createSquad:InvokeServer("Leaf Hub Party")
                end
            end)

            task.wait(2)
            setRaidStatus("Teleporting to Pods...")

            -- Teleport to center of Pods folder (inside TrueHeadquarters Platform model)
            local platform = workspace:FindFirstChild("TrueHeadquarters Platform")
            local pods = platform and platform:FindFirstChild("Pods")
                      or workspace:FindFirstChild("Pods") -- fallback direct
            if pods then
                local parts = pods:GetChildren()
                if #parts > 0 then
                    local sum   = Vector3.new(0, 0, 0)
                    local count = 0
                    for _, p in ipairs(parts) do
                        local pos = getPosition(p)
                        if pos then sum += pos; count += 1 end
                    end
                    if count > 0 then
                        safeTeleport(sum / count)
                    else
                        local pos = getPosition(parts[1])
                        if pos then safeTeleport(pos) end
                    end
                end
            else
                setRaidStatus("Pods not found in TrueHeadquarters Platform!")
            end

            task.wait(2)
            -- Spam transition remotes while we wait to load into raid
            setRaidStatus("Loading into raid...")
            spamTransitionRemotes(10)

            continue
        end

        -- ── RAID PHASE ────────────────────────────────────────────────────────
        local raidLoc = RAID_MAP[currentPlaceId]
        if not raidLoc then
            setRaidStatus("Unknown place (" .. tostring(currentPlaceId) .. ")")
            task.wait(5)
            continue
        end

        -- Spam transition remotes briefly at start of each place load
        spamTransitionRemotes(3)

        -- Read extraction target from QuestUI
        local extractionTitle = nil
        local waitStart = tick()
        while not extractionTitle and tick() - waitStart < 15 do
            extractionTitle = getExtractionTarget()
            if not extractionTitle then task.wait(1) end
        end

        if not extractionTitle then
            setRaidStatus("Could not find extraction target!")
            task.wait(5)
            continue
        end

        setRaidStatus("Target: " .. extractionTitle)
        task.wait(1)

        -- Are we already at the extraction location?
        local destPlaceId, destLoc = matchLocation(extractionTitle)
        if destPlaceId and destPlaceId == currentPlaceId then
            setRaidStatus("At extraction! Done.")
            Library.Toggles.AutoRaid:SetValue(false)
            continue
        end

        -- Find which exit to take
        local exit = findExitToward(currentPlaceId, extractionTitle:match(":%s*(.+)") or extractionTitle)
        if not exit then
            setRaidStatus("No path to " .. extractionTitle)
            task.wait(5)
            continue
        end

        setRaidStatus("Moving to " .. exit.dest .. " exit...")
        safeTeleport(exit.pos)
        task.wait(opt("RaidMoveDelay") or 2)

        -- Spam transition remotes as we go through the exit
        spamTransitionRemotes(5)
    end
end)
