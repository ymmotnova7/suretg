-- Exit ESP render loop
RunService.RenderStepped:Connect(function()
    if not tog("ExitESP") or #activeExits == 0 then
        for _, e in ipairs(activeExits) do
            e.name.Visible   = false
            e.dist.Visible   = false
            e.tracer.Visible = false
        end
        return
    end

    local myHRP     = getHRP()
    local camera    = workspace.CurrentCamera
    local vpSize    = camera.ViewportSize
    local screenMid = Vector2.new(vpSize.X * 0.5, vpSize.Y)
    local maxDist   = opt("ExitESPMaxDist") or 5000
    local color     = opt("ExitESPColor")   or Color3.fromRGB(80, 255, 180)
    local showDist  = tog("ExitESPDistance")
    local LINE_H    = 18  -- pixels per line of text

    -- Track vertical offset per screen position bucket so stacked exits
    -- don't overlap. Key = "rx,ry" rounded to nearest 4px.
    local stackOffsets = {}

    for _, e in ipairs(activeExits) do
        local dist = myHRP and (myHRP.Position - e.pos).Magnitude or 0
        if dist > maxDist then
            e.name.Visible   = false
            e.dist.Visible   = false
            e.tracer.Visible = false
            continue
        end

        local sp, onScreen = worldToScreen(e.pos)
        if not onScreen then
            e.name.Visible   = false
            e.dist.Visible   = false
            e.tracer.Visible = false
            continue
        end

        -- Bucket this screen position to detect duplicates
        local bx = math.floor(sp.X / 4)
        local by = math.floor(sp.Y / 4)
        local key = bx .. "," .. by
        local slot = stackOffsets[key] or 0
        stackOffsets[key] = slot + 1

        -- How many lines does this slot take up (name + optional dist)
        local linesPerEntry = showDist and 2 or 1
        local yOffset = slot * (linesPerEntry * LINE_H)

        -- Name
        e.name.Text     = e.label
        e.name.Color    = color
        e.name.Position = Vector2.new(sp.X, sp.Y - 10 - yOffset)
        e.name.Visible  = true

        -- Distance
