end)

-- ─── Auto Curse M1s ───────────────────────────────────────────────────────────
-- Detects left mouse clicks (M1) via UserInputService.InputBegan.
-- Fires Curse + E on the first click of a combo, CurseOff after the combo window.
local VK_E          = 0x45
local curseActive   = false
local lastCurseTick = 0

local function getCurseRemotes()
    local char = getChar()
    if not char then return nil, nil end
    local requests = char:FindFirstChild("CharacterHandler")
                  and char.CharacterHandler:FindFirstChild("Requests")
    if not requests then return nil, nil end
    return requests:FindFirstChild("Curse"), requests:FindFirstChild("CurseOff")
end

local function pressE()
    pcall(function()
        if isrbxactive and not isrbxactive() then return end
        keypress(VK_E)
    end)
    pcall(function()
        local vu = game:GetService("VirtualUser")
        vu:CaptureController(); vu:KeyDown(string.char(VK_E))
    end)
end

local function releaseE()
    pcall(function()
        if isrbxactive and not isrbxactive() then return end
        keyrelease(VK_E)
    end)
    pcall(function()
        local vu = game:GetService("VirtualUser")
        vu:KeyUp(string.char(VK_E))
    end)
end

local function doCurseOff()
    local _, curseOffR = getCurseRemotes()
    if curseOffR then pcall(function() curseOffR:FireServer(Players.LocalPlayer) end) end
    releaseE()
    curseActive = false
end

local function doCurse()
    if not tog("AutoCurse") then return end
    -- Only trigger on the first M1 of a combo, ignore rapid successive clicks
    local comboWindow = opt("CurseComboWindow") or 1.5
    if tick() - lastCurseTick < comboWindow then return end
    lastCurseTick = tick()

    local curseR, _ = getCurseRemotes()
    if curseR then pcall(function() curseR:FireServer(Players.LocalPlayer, false) end) end
    pressE()
    curseActive = true

    task.delay(comboWindow * 0.9, function()
        if curseActive then doCurseOff() end
    end)
end

-- Listen for left mouse clicks — fires only when the player actually clicks,
-- not from walking, animations, or any other game logic.
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        doCurse()
    end
end)

Library.Toggles.AutoCurse:OnChanged(function(state)
    if not state and curseActive then doCurseOff() end
end)
