-- Project a 3D world position to 2D screen position.
-- Returns screenPos (Vector2), onScreen (bool)
local function worldToScreen(pos)
    local camera = workspace.CurrentCamera
    local sp, vis = camera:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), vis and sp.Z > 0
end

-- Get an approximate bounding box in screen space for a character/model.
-- Returns topLeft (Vector2), bottomRight (Vector2), onScreen (bool)
local function getModelScreenBounds(part, heightOverride)
    local camera = workspace.CurrentCamera
    local height = heightOverride or 5.5
    local pos    = part.Position

    -- Project top and bottom of the character
    local top    = pos + Vector3.new(0, height * 0.5, 0)
    local bottom = pos - Vector3.new(0, height * 0.5, 0)

    local topSP,    topVis    = camera:WorldToViewportPoint(top)
    local bottomSP, bottomVis = camera:WorldToViewportPoint(bottom)

    if not topVis or not bottomVis or topSP.Z <= 0 or bottomSP.Z <= 0 then
        return nil, nil, false
    end

    local screenHeight = bottomSP.Y - topSP.Y
    local screenWidth  = screenHeight * 0.6  -- approximate aspect ratio

    local centerX = topSP.X
    local topY    = topSP.Y
    local botY    = bottomSP.Y

    local tl = Vector2.new(centerX - screenWidth * 0.5, topY)
    local br = Vector2.new(centerX + screenWidth * 0.5, botY)
    return tl, br, true
end

