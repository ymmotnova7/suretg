-- ── Exit teleport (workspace.MapStuff.Map.Spawns > nearest "Exit" part) ───────
AutoTPBox:AddButton("TP to Exit", function()
    local mapStuff = workspace:FindFirstChild("MapStuff")
    local map      = mapStuff and mapStuff:FindFirstChild("Map")
    local spawns   = map and map:FindFirstChild("Spawns")
    if not spawns then Library:Notify("Spawns folder not found!", 3); return end
    local exits = {}
    for _, v in ipairs(spawns:GetChildren()) do
        if v:IsA("BasePart") and v.Name == "Exit" then table.insert(exits, v) end
    end
    if #exits == 0 then Library:Notify("No Exit parts found!", 3); return end
    local hrp    = getHRP()
    local target = exits[1]
    if hrp and #exits > 1 then
        local minDist = math.huge
        for _, e in ipairs(exits) do
            local d = (hrp.Position - e.Position).Magnitude
            if d < minDist then minDist = d; target = e end
        end
    end
    safeTeleport(target.Position)
    Library:Notify("Teleported to Exit!", 2)
end)

-- ── Hidden Curse cycler (any model in workspace with a "VeilHighlight" child) ──
-- These are curse quest objectives — cycle through them one per press.
local cycleHiddenCurses = makeCycler(
    "Hidden Curse",
    function()
        local t = {}
        -- Search all workspace descendants for models containing a VeilHighlight
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("Highlight") and v.Name == "VeilHighlight" then
                -- The model is the parent of the highlight
                local model = v.Parent
                if model and model:IsA("Model") then
                    -- Avoid duplicates
                    local already = false
                    for _, existing in ipairs(t) do
                        if existing == model then already = true; break end
                    end
                    if not already then table.insert(t, model) end
                end
            end
        end
        return t
    end,
    function(v) return getPosition(v) end
)
AutoTPBox:AddButton("TP to Hidden Curse", cycleHiddenCurses)

