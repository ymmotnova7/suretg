-- Match a quest title string to a location name (handles aliases and partial matches)
local function matchLocation(titleStr)
    if not titleStr or titleStr == "" then return nil end
    local lower = titleStr:lower()
    -- Extract destination from "Extraction Point: X" format
    local dest = lower:match("extraction point:%s*(.+)") or lower
    dest = dest:gsub("%s+$", "")

    for placeId, loc in pairs(RAID_MAP) do
        if loc.name:lower():find(dest, 1, true) or dest:find(loc.name:lower(), 1, true) then
            return placeId, loc
        end
        if loc.aliases then
            for _, alias in ipairs(loc.aliases) do
                if alias:lower():find(dest, 1, true) or dest:find(alias:lower(), 1, true) then
                    return placeId, loc
                end
            end
        end
    end
    return nil
end

-- Get the extraction target from QuestUI
local function getExtractionTarget()
    local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if not playerGui then return nil end

    local questUI = playerGui:FindFirstChild("QuestUI")
    if not questUI then return nil end

    local questFrame = questUI:FindFirstChild("Quest")
    if not questFrame then return nil end

    -- Search all TextLabels named "Title" in Header frames
    for _, child in ipairs(questFrame:GetChildren()) do
        local header = child:FindFirstChild("Header")
        if header then
            local title = header:FindFirstChild("Title")
            if title and title:IsA("TextLabel") then
                local text = title.Text
                if text and text ~= "" then
                    -- Match "Extraction Point: <Location>"
                    if text:lower():find("extraction") then
                        return text
                    end
                end
            end
        end
    end

    -- Fallback: also check QuestTemplate directly
    local template = questFrame:FindFirstChild("QuestTemplate")
    if template then
        local header = template:FindFirstChild("Header")
        local title  = header and header:FindFirstChild("Title")
        if title and title.Text ~= "" then return title.Text end
    end

    return nil
end

-- Find the exit from current location heading toward a destination
local function findExitToward(currentPlaceId, destName)
    local loc = RAID_MAP[currentPlaceId]
    if not loc then return nil end

    local destLower = destName:lower()

    -- Direct exit to destination
    for _, exit in ipairs(loc.exits) do
        if exit.dest:lower():find(destLower, 1, true) or destLower:find(exit.dest:lower(), 1, true) then
            return exit
        end
    end

    -- BFS to find path through the map
    local queue   = { { id = currentPlaceId, path = {} } }
    local visited = { [currentPlaceId] = true }
    while #queue > 0 do
        local node = table.remove(queue, 1)
        local nodeLoc = RAID_MAP[node.id]
        if nodeLoc then
            for _, exit in ipairs(nodeLoc.exits) do
                -- Find placeId of dest
                local nextId = nil
                for pid, ploc in pairs(RAID_MAP) do
                    if ploc.name:lower() == exit.dest:lower() then
                        nextId = pid; break
                    end
                    if ploc.aliases then
                        for _, alias in ipairs(ploc.aliases) do
                            if alias:lower() == exit.dest:lower() then nextId = pid; break end
                        end
                    end
                end
                if nextId and not visited[nextId] then
                    local newPath = {}
                    for _, e in ipairs(node.path) do table.insert(newPath, e) end
                    table.insert(newPath, exit)

                    -- Check if this node's exits lead to destination
                    local nextLoc = RAID_MAP[nextId]
                    if nextLoc then
                        if nextLoc.name:lower():find(destLower, 1, true) or destLower:find(nextLoc.name:lower(), 1, true) then
                            -- Return the first exit in the path
                            return newPath[1]
                        end
                        if nextLoc.aliases then
                            for _, alias in ipairs(nextLoc.aliases) do
                                if alias:lower():find(destLower, 1, true) then
                                    return newPath[1]
                                end
                            end
                        end
                    end

                    visited[nextId] = true
                    table.insert(queue, { id = nextId, path = newPath })
                end
            end
        end
    end

    -- No path found — just return first exit as fallback
    if #loc.exits > 0 then return loc.exits[1] end
    return nil
end

-- Spam the travel story + choice remotes during loading screens
local function spamTransitionRemotes(duration)
    local RS = game:GetService("ReplicatedStorage")
    local deadline = tick() + duration
    local stories = {
        "Lets hope it can bring safe travels - Make a prayer",
        "Keep moving forward",
        "Stay sharp",
    }
    local storyIdx = 1

    while tick() < deadline do
        -- TravelStory remote
        pcall(function()
            local r = RS:FindFirstChild("Requests")
            if r then
                local ts = r:FindFirstChild("TravelStory")
                if ts then ts:FireServer(stories[storyIdx]) end
                storyIdx = (storyIdx % #stories) + 1
            end
        end)

        -- Choice remote (dismisses selection screens)
        pcall(function()
            local choice = RS:FindFirstChild("Choice") or
                           (RS:FindFirstChild("Requests") and RS.Requests:FindFirstChild("Choice"))
            if choice then choice:FireServer(false) end
        end)

        -- Also press L key
        pcall(function()
            if isrbxactive and not isrbxactive() then return end
            keypress(0x4C); task.wait(0.05); keyrelease(0x4C)
        end)
        pcall(function()
            local vu = game:GetService("VirtualUser")
            vu:CaptureController(); vu:KeyDown("l"); task.wait(0.05); vu:KeyUp("l")
        end)

        task.wait(0.2)
    end
end

