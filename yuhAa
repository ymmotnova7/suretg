-- Windows Virtual Key code for X
local VK_X = 0x58

-- Press X using every available method simultaneously so it works on any executor
local function pressX()
    -- 1. keypress/keyrelease (Synapse X, KRNL, most modern executors — uses Windows VK codes)
    pcall(function()
        if isrbxactive and not isrbxactive() then return end
        keypress(VK_X)
    end)

    -- 2. VirtualUser (built-in Roblox, works in some executors)
    pcall(function()
        local vUser = game:GetService("VirtualUser")
        vUser:CaptureController()
        vUser:KeyDown(string.char(VK_X))
    end)

    task.wait(0.08)

    -- Release both methods
    pcall(function()
        if isrbxactive and not isrbxactive() then return end
        keyrelease(VK_X)
    end)
    pcall(function()
        local vUser = game:GetService("VirtualUser")
        vUser:KeyUp(string.char(VK_X))
    end)
end

-- Fire any ProximityPrompts on a part
local function firePrompts(part)
    pcall(function()
        for _, d in ipairs(part:GetDescendants()) do
            if d:IsA("ProximityPrompt") then
                fireproximityprompt(d)
            end
        end
        local pp = part:FindFirstChildOfClass("ProximityPrompt")
        if pp then fireproximityprompt(pp) end
    end)
end

-- Spam X + ProximityPrompts at a part until it disappears or timeout (seconds)
local function spamCollect(part, toggleKey, timeout)
    timeout = timeout or 1
    local deadline = tick() + timeout

    while tick() < deadline and tog(toggleKey) do
        -- Stop the moment the part is gone — no need to wait out the timeout
        if not part or not part.Parent then break end
        firePrompts(part)
        pressX()
        task.wait(0.05)
    end

    -- Always release cleanly on exit
    pcall(function() keyrelease(VK_X) end)
    pcall(function()
        local vUser = game:GetService("VirtualUser")
        vUser:KeyUp(string.char(VK_X))
    end)
end

-- Generic farm loop: rescan every pass, TP to each, spam collect, wait configurable delay
local function runFarmLoop(toggleKey, scanFn, delayKey, defaultDelay)
    while true do
        task.wait(0.05)
        if not tog(toggleKey) then continue end

        local parts = scanFn()

        if #parts == 0 then
            task.wait(0.5)
            continue
        end

        for _, part in ipairs(parts) do
            if not tog(toggleKey) then break end
            if not part or not part.Parent then continue end

            safeTeleport(part.Position)
            task.wait(0.2) -- settle after teleport

            -- Spam X for up to the delay duration — exits early if part disappears
            local delay = opt(delayKey) or defaultDelay
            if part and part.Parent then
                spamCollect(part, toggleKey, delay)
            end

            -- Any remaining gap (if part vanished early) — still honour the full delay
            -- so we don't instantly snap to the next part before the game processes it
            task.wait(0.1)
        end

        task.wait(0.1)
    end
end

