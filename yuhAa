-- NPC name whitelist — these are NPCs not mobs even though they follow the dot/digit pattern.
-- Add more names here as you find them. Matching is case-insensitive and partial.
local NPC_NAMES = {
    "cowardvillager",
    "coward",
    "cowardvillagerhaven",
    "havenvillager",
    "villager",
}

local function isNPCName(raw)
    local lower = raw:lower()
    -- Strip leading dot and trailing digits to get the base name for matching
    local base = lower:gsub("^%.", ""):gsub("%d+$", ""):gsub("%s+$", "")
    for _, n in ipairs(NPC_NAMES) do
        if base:find(n, 1, true) then return true end
    end
    return false
end

local function hookLiveChild(child)
    if not child:IsA("Model") then return end
    if Players:GetPlayerFromCharacter(child) then return end

    -- Categorize: check NPC whitelist first, everything else is a Mob
    local category = isNPCName(child.Name) and "NPC" or "Mob"
    local label    = cleanMobName(child.Name)  -- clean applies to both

    -- The HumanoidRootPart may not exist yet when ChildAdded fires for a freshly
    -- spawning mob — wait up to 2s for it before giving up.
    task.spawn(function()
        local hrp = child:FindFirstChild("HumanoidRootPart")
        if not hrp then
            hrp = child:WaitForChild("HumanoidRootPart", 2)
        end

        -- Also accept any BasePart as fallback if still no HRP
        local function gp()
            if not child or not child.Parent then return nil end
            return child:FindFirstChild("HumanoidRootPart")
                or child:FindFirstChildOfClass("BasePart")
        end

        if not gp() then return end  -- truly nothing there, skip

        addESP(child, gp, category, label)
    end)
end

local function hookLiveFolder(folder)
    if not folder then return end
    for _, c in ipairs(folder:GetChildren()) do
