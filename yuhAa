-- ─────────────────────────────────────────────────────────────────────────────
--  Visual removals — event-driven (no per-frame loop = no flashing)
--  We hook GetPropertyChangedSignal so we fight the game the instant it reverts.
-- ─────────────────────────────────────────────────────────────────────────────
local fogConnections  = {}
local blurConnections = {}

local function applyFog()
    Lighting.FogStart = 9e9
    Lighting.FogEnd   = 9e9
    local a = Lighting:FindFirstChildOfClass("Atmosphere")
    if a then a.Density = 0 end
end
local function restoreFog()
    Lighting.FogStart = origFogStart
    Lighting.FogEnd   = origFogEnd
    local a = Lighting:FindFirstChildOfClass("Atmosphere")
    if a and origAtmoDens ~= nil then a.Density = origAtmoDens end
end

local function hookAtmosphere(a)
    table.insert(fogConnections, a:GetPropertyChangedSignal("Density"):Connect(function()
        if tog("NoFog") then a.Density = 0 end
    end))
end

local function enableNoFog()
    applyFog()
    -- Re-suppress whenever the game reverts these properties
    table.insert(fogConnections, Lighting:GetPropertyChangedSignal("FogStart"):Connect(function()
        if tog("NoFog") then Lighting.FogStart = 9e9 end
    end))
    table.insert(fogConnections, Lighting:GetPropertyChangedSignal("FogEnd"):Connect(function()
        if tog("NoFog") then Lighting.FogEnd = 9e9 end
    end))
    local a = Lighting:FindFirstChildOfClass("Atmosphere")
    if a then hookAtmosphere(a) end
    -- Handle Atmosphere added after the fact
    table.insert(fogConnections, Lighting.ChildAdded:Connect(function(child)
        if tog("NoFog") and child:IsA("Atmosphere") then
            child.Density = 0
            hookAtmosphere(child)
        end
    end))
end
local function disableNoFog()
    for _, c in ipairs(fogConnections) do c:Disconnect() end
    fogConnections = {}
    restoreFog()
end

local function enableNoBlur()
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("BlurEffect") then
            v.Size = 0
            table.insert(blurConnections, v:GetPropertyChangedSignal("Size"):Connect(function()
                if tog("NoBlur") then v.Size = 0 end
            end))
        end
    end
    table.insert(blurConnections, Lighting.ChildAdded:Connect(function(child)
        if tog("NoBlur") and child:IsA("BlurEffect") then
            child.Size = 0
            table.insert(blurConnections, child:GetPropertyChangedSignal("Size"):Connect(function()
                if tog("NoBlur") then child.Size = 0 end
            end))
        end
    end))
end
local function disableNoBlur()
    for _, c in ipairs(blurConnections) do c:Disconnect() end
    blurConnections = {}
    for v, s in pairs(origBlurSizes) do if v and v.Parent then v.Size = s end end
end

