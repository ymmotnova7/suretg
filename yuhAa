        if UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then x += 1 end

        local vel = cam.CFrame:VectorToWorldSpace(Vector3.new(x, 0, z) * (opt("FlySpeed") or 200))
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)       then vel += Vector3.new(0,  opt("FlyUpSpeed") or 150, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then vel += Vector3.new(0, -(opt("FlyUpSpeed") or 150), 0) end
        flyBV.Velocity = vel
    else
        if flyBV then stopFly() end
    end

    -- ── Speedhack ──────────────────────────────────────────────────────────
    if tog("Speedhack") and not tog("Fly") and hum then
        hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity * Vector3.new(0, 1, 0)
        local dir = hum.MoveDirection
        if dir.Magnitude > 0.001 then hrp.AssemblyLinearVelocity += dir.Unit * (opt("SpeedhackSpeed") or 200) end
    end

    -- ── CFrame Speed ───────────────────────────────────────────────────────
    if tog("CFrameSpeed") and not tog("Fly") and hum then
        local dir = hum.MoveDirection
        if dir.Magnitude > 0.001 then hrp.CFrame += dir * ((opt("CFrameSpeedMult") or 1) * dt) end
    end

    -- ── Pathfind Breaker ───────────────────────────────────────────────────
    if tog("PathfindBreaker") then
        pbLastVel = hrp.AssemblyLinearVelocity
        hrp.AssemblyLinearVelocity = tog("AggressiveMode") and Vector3.new(0,-1e5,0) or Vector3.new(0,-9e9,0)
        if tog("PBHighlight") then
            if not pbHighlight or not pbHighlight.Parent then
                pbHighlight = Instance.new("Highlight"); pbHighlight.Parent = char
            end
            pbHighlight.FillColor    = opt("PBHighlightColor")        or Color3.fromRGB(200,0,255)
            pbHighlight.OutlineColor = opt("PBHighlightOutlineColor") or Color3.fromRGB(255,152,234)
        else
            if pbHighlight then pbHighlight:Destroy(); pbHighlight = nil end
        end
    else
        pbLastVel = nil
        if pbHighlight then pbHighlight:Destroy(); pbHighlight = nil end
    end
end)

RunService.PreRender:Connect(function()
    if not pbLastVel then return end
    local hrp = getHRP(); if hrp then hrp.AssemblyLinearVelocity = pbLastVel end
end)

