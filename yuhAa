            e.dist.Text     = ("[%d studs]"):format(math.floor(dist))
            e.dist.Color    = color
            e.dist.Position = Vector2.new(sp.X, sp.Y + 6 - yOffset)
            e.dist.Visible  = true
        else
            e.dist.Visible = false
        end

        -- Tracer (only draw for slot 0 — one tracer per position is enough)
        if tog("ExitESPTracers") and slot == 0 then
            e.tracer.From    = screenMid
            e.tracer.To      = sp
            e.tracer.Color   = color
            e.tracer.Visible = true
        else
            e.tracer.Visible = false
        end
    end
end)

